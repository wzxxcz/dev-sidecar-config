		"intercepts": {
			//region GitHub相关
			"github.com": {
				"^/?(\\?.*)?$": {
					"cacheDays": 7,
					"cacheImmutable": false,
					"desc": "首页：缓存7天，可以按 “F5” 来重新加载，不需要 “Ctrl+F5” 强制刷新"
				},
				"^(/[^/]{1,35}){1,2}/?(\\?.*)?$": {
					"cacheDays": 7,
					"cacheImmutable": false,
					"etagCacheKeyGenerationStrategy": {
						"headers": ["Turbo-Frame"],
						"desc": "Turbo-Frame 请求头，是github的一个请求头，它区分于整个页面刷新与菜单点击刷新页面。两种方式的响应内容不一样，所以缓存也区分开来。"
					},
					"desc": "所有一级和二级目录页面：缓存7天，可以按 “F5” 来重新加载，不需要 “Ctrl+F5” 强制刷新"
				},
				"^(/[^/]{1,35}){2}/(issue|pull|discussion|wiki|project|security|pulse|fork|network/\\w+|graphs/[\\w-]{1,16}|community|)s?/?(\\?.*)?$": {
					"cacheDays": 7,
					"cacheImmutable": false,
					"etagCacheKeyGenerationStrategy": {
						"headers": ["Turbo-Frame"],
						"desc": "Turbo-Frame 请求头，是github的一个请求头，它区分于整个页面刷新与菜单点击刷新页面。两种方式的响应内容不一样，所以缓存也区分开来。"
					},
					"desc": "一些三级目录页面：缓存7天，可以按 “F5” 来重新加载，不需要 “Ctrl+F5” 强制刷新"
				},
				"^(/[^/]{1,35}){2}/(issue|pull|discussion)s?/\\d+/?(\\?.*)?$": {
					"cacheMinutes": 5,
					"cacheImmutable": false,
					"desc": "Issue、PR、Discussion详情页：缓存1天，可以按 “F5” 来重新加载，不需要 “Ctrl+F5” 强制刷新"
				},
				"/fluidicon.png": {
					"cacheDays": 365,
					"desc": "Github那只猫的图片，缓存1年"
				},
				"^(/[^/]{1,35}){2}/pull/\\d+/open_with_menu.*$": {
					"cacheDays": 30,
					"desc": "PR详情页：标题右边那个Code按钮的HTML代理请求地址，感觉上应该可以缓存。暂时先设置为缓存1个月"
				},
				"/apache/incubator-seata/security/overall-count": {
					"cacheDays": 1,
					"desc": "获取导航栏上 “Security” 数量的接口，缓存1天"
				},
				"^/users/[^/]+/hovercard(\\?.*)?$": {
					"cacheDays": 30,
					"desc": "鼠标移到头像上弹出的卡片内容，我个人一般很少去看它，缓存1个月"
				},
				"^(/[^/]{1,35}){2}/(branch|tag)\\-count(\\?.*)?$": {
					"cacheDays": 15,
					"desc": "仓库中，获取Branches和Tags的数量的接口，缓存15天"
				},
				"^(/[^/]{1,35}){2}/(issue|pull|discussion)s?/\\d+/hovercard(\\?.*)$": {
					"cacheDays": 30,
					"desc": "鼠标移到Issue、PR、Discussion时弹出的卡片内容，我个人一般很少去看它，缓存1个月"
				},
				"/notifications/indicator": {
					"cacheDays": 7,
					"desc": "通知类型接口，缓存7天"
				},
				"/.*/.*/blame/": null,
				"^/notifications/\\d+/watch_subscription.*$": {
					"cacheDays": 7
				},
				"^(/[^/]{1,35}){2}/overview-files/.*$": {
					"cacheDays": 7
				},
				"^(/[^/]{1,35}){2}/hovercards/citation/sidebar_partial$": {
					"cacheDays": 7
				},
				"^(/[^/]{1,35}){2}/(latest-commit|tree-commit-info)/.*$": {
					"cacheDays": 1
				},
				"^(/[^/]{1,35}){2}/(contributors_list|used_by_list|hovercards/citation/sidebar_partial|recently-touched-branches)(\\?.*)?$": {
					"cacheDays": 7,
					"desc": "仓库首页，四个接口，缓存7天"
				},
				"^(/[^/]{1,35}){2}/spoofed_commit_check/.+$": {
					"cacheDays": 7,
					"desc": "缓存7天"
				}
			},
			"raw.githubusercontent.com": {
				"^.*\\.(jpg|jpeg|png|gif|svg)(\\?.*)?$": {
					"cacheDays": 365,
					"exclusions": {
						"^(/[^/]+){2}/refs/heads/.*$": "仓库内页查看文件时，不采用当前缓存策略"
					}
				}
			},
			"*.githubcopilot.com": {
				".*": {
					"options": true
				}
			},
			"customer-stories-feed.github.com": {
				".*": {
