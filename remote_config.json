{
  "server": {
    "intercepts": {
      //配置编辑时间、版本信息
      "metaInfo": {
        // 从语义上说，元信息不该插在这里，但是好像放在这里容易debug；所幸不会有网站叫metaInfo
        "version": 202602231340, // 格式是GMT+8的开始编辑时间，固定位数为年月日+时分;一天有1440分钟，够用了；这就是个number,可以用来比较，别加引号
        "updateLog": "更新ms-sso.copilot.microsoft.com规则,防止微软登录卡登录", // 我真的不觉得这个字段有多大必要
        "id": "official" // 配置id：id区分大小写，只能带有大小写字母、数字、点号与横杠，应当具有说明作用（所以不许用一串数字/乱码代替）
        // dev-sidecar从2.0.2开始内置的配置是internal，这里是official
        // 第三方配置应使用Java风格id,即发布网站域名的倒序，但严禁使用com.example之类的烂大街id（com.example保留为示范用途）
        // 同理禁止使用com.github/com.gitee/com.gitcode/io.github等大概率托管多个配置的网站域名倒序
        // 托管在github的均推荐在个人的自定义github.io域名上发布；其他易重复网站，可在域名的最后一部分加上自定义名称用来区分，如com.gitee.alice
        // user/local/test保留给不会公开发布的本地配置使用；以防万一，所有不带点号的id都被保留使用
        // 只有**等价**的配置出现在不同URL时（比如不同镜像之间）、一份配置的更新迭代之间可以使用相同的id；一份配置变更发布地址时可以保留原有id
        // 定义**等价**的配置为结构相同、字段完全相同且同一字段的内容完全相同，
        // 也就是说配置规约为JSON格式后，所有平级字段之间按ASCII增序排列，删除所有不在字符串中的空白字符得到的内容相同
        // （所有配置都可以通过补全字段字符串引号、删除尾随逗号及所有注释规约为标准JSON；配置中的字段只能是7位ASCII中的可见字符）
      },

      // github相关
      "github.com": {
        "^(/[^/]+){2,}/?(\\?.*)?$": {
          "tampermonkeyScript": "https://gitee.com/wangliang181230/dev-sidecar/raw/scripts/tampermonkey.js",
          "script": "https://gitee.com/wangliang181230/dev-sidecar/raw/scripts/GithubEnhanced-High-Speed-Download.user.js",
          "remark": "注：上面所使用的脚本地址，为高速镜像地址。",
          "desc": "油猴脚本：高速下载 Git Clone/SSH、Release、Raw、Code(ZIP) 等文件 (公益加速)、项目列表单文件快捷下载、添加 git clone 命令"
        },
        "^(/[\\w-.]+){2,}/?(\\?.*)?$": null,
        // 以下配置会导致私有(private)仓库中的图片无法加载，因为需要有一个token参数，无法在DS中生成，暂不配置
        //"^((/[^/]+){2})/raw/(refs/heads/)?(.*)$": {
        //	"proxy": "https://raw.githubusercontent.com${m[1]}/${m[4]}",
        //	"sni": "baidu.com",
        //	"requestReplace": {
        //		"headers": {
        //			"cookie": "[remove]",
        //			"user-agent": "[remove]"
        //		}
        //	}
        //},
        "^((/[^/]+){2,})/raw((/[^/]+)+\\.(jpg|jpeg|png|gif))(\\?.*)?$": {
          "proxy": null,
          "sni": null,
          "cacheDays": 365,
          "desc": "仓库内图片重定向，缓存1年。"
        },
        "^((/[^/]+){2,})/raw((/[^/]+)+\\.js)(\\?.*)?$": {
          "proxy": null,
          "sni": null,
          "responseReplace": {
            "headers": {
              "content-type": "application/javascript; charset=utf-8"
            }
          },
          "desc": "仓库内脚本，设置响应头Content-Type。作用：方便script拦截器直接使用，避免引起跨域问题和脚本内容限制问题。"
        }
      },
      "api.github.com": {
        ".*": {
          "sni": "baidu.com"
        }
      },
      "github.githubassets.com": {
        "/assets/fakefile.js": {
          "abort": true,
          "cacheDays": 365
        },
        "^(/[^/]+)*/[^./]+\\.(svg|png|gif|jpg|jpeg|ico|js|css)(\\?.*)?$": {
          "cacheDays": 365,
          "desc": "图片、JS文件、CSS文件，缓存1年"
        },
        ".*.backup": {
          "desc": "github.com域名下，该请求已经不存在，此配置暂时先备份掉。",
          "proxy": "github.com",
          "sni": "baidu.com",
          "responseReplace": {
            "headers": {
              "access-control-allow-origin": "*",
              "cross-origin-resource-policy": "cross-origin",
              "set-cookie": "[remove]"
            }
          }
        }
      },
      "opengraph.githubassets.com": {
        "^/(([^/]+/){3}issues/\\d+)?(\\?.*)?$": {
          "cacheDays": 365
        },
        ".*": {
          "sni": "baidu.com"
        }
      },
      "*.githubusercontent.com": {
        ".*": {
          "sni": "baidu.com",
          "requestReplace": {
